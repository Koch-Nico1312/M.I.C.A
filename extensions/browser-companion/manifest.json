{
  "manifest_version": 3,
  "name": "M.I.C.A Companion",
  "version": "0.1.0",
  "description": "Verbindet Browser und Mobilgerät sicher mit M.I.C.A, Arbeitsbereichen und Kommunikation.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "M.I.C.A Companion",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
