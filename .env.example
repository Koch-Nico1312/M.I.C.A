# JARVIS Configuration File
# Copy this to .env and fill in your values

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Model Configuration
LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
TEXT_MODEL=gemini-2.5-flash
VISION_MODEL=gemini-2.5-flash

# Local LLM Fallback (Ollama)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_FALLBACK_ONLY=false

# Audio Configuration
CHANNELS=1
SEND_SAMPLE_RATE=16000
RECEIVE_SAMPLE_RATE=24000
CHUNK_SIZE=1024

# Passive Vision System
PASSIVE_VISION_ENABLED=false
PASSIVE_VISION_INTERVAL=30
PASSIVE_VISION_MEMORY_MINUTES=10

# Semantic Search (RAG)
RAG_ENABLED=false
RAG_VECTOR_DB=chromadb
RAG_INDEX_PATH=./data/vector_db
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# Screen Overlay HUD
HUD_ENABLED=false
HUD_TRANSPARENCY=0.7
HUD_HIGHLIGHT_COLOR=#00ff00

# Proactive Suggestions
PROACTIVE_SUGGESTIONS_ENABLED=true
PROACTIVE_SUGGESTIONS_INTERVAL=60

# Voice Emotional Analysis
EMOTION_ANALYSIS_ENABLED=true

# Cross-Device Handover
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# VS Code Integration
VSCODE_BRIDGE_ENABLED=false
VSCODE_PORT=8080

# Gmail Integration
GMAIL_ENABLED=true

# Google Calendar
CALENDAR_ENABLED=true

# Daily Briefing
BRIEFING_ENABLED=false
BRIEFING_MORNING_TIME=08:00
BRIEFING_EVENING_TIME=21:00

# Spotify
SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Session Persistence
SESSION_CONTEXT_ENABLED=true

# Obsidian Vault Integration
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT_PATH="C:\nova\Nova Gedächtnis"

# Stealth Mode
STEALTH_MODE=false
