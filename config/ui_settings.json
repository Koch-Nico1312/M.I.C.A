{
  "model_router": {
    "preferred_profile": "fast",
    "model_scope": "linked",
    "cost_mode": "balanced"
  },
  "ollama": {
    "enabled": true,
    "model": "llama3.1",
    "base_url": "http://localhost:11434"
  },
  "ui": {
    "default_view": "home",
    "voice_first": true,
    "background_id": "lake",
