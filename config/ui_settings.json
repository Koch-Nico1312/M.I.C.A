    "theme": "dark"
  },
  "calendar": {
    "enabled": false,
    "credentials_path": "./config/gmail_credentials.json",
    "token_path": "./config/calendar_token.json"
  },
  "personal_mode": {
    "active_mode": "focus",
    "trust_level": 2
  },
  "proactive": {
    "mode": "off"
  }
}